# Absolute path to this project on the host machine.
# Required on Windows where $PWD is not set in the docker-compose environment.
# Example (Windows):  HOST_PWD=C:/Users/you/projects/Spectral
# Example (Linux/Mac): HOST_PWD=/home/you/projects/Spectral
# Docker Compose v2 on Linux/Mac sets COMPOSE_PROJECT_DIR automatically, so
# this variable is only needed if the worker logs show volume mount errors.
